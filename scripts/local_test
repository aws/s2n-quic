# This script runs basic checks to verify code will pass through the CI.

set -e

"$(dirname "$0")/typos"
"$(dirname "$0")/copyright_check"
cargo +nightly fmt --all -- --check
cargo +stable clippy --all-features --all-targets -- -D warnings
cargo test
