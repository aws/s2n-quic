  rankdir=LR;
  compound=true;
  subgraph cluster_worker_0 {
    label="worker 0";
  }
  subgraph cluster_worker_1 {
    label="worker 1";
    w1_t0 [shape=box,label="task.producer\\nfn: tests::producer\\nbudget: 32\\nmetrics: task.producer.drained [summary unit=count]: Number of items processed per poll for this task\\ntask.producer.time [timer unit=microsecond]: Wall-clock duration spent inside each task poll\\ntask.producer.next_poll_latency [timer unit=microsecond]: Wall-clock latency between consecutive task polls\\nProduces work for downstream pipeline stages"];
    w1_t1 [shape=box,label="task.consumer\\nfn: tests::consumer\\nbudget: none\\nmetrics: task.consumer.drained [summary unit=count]: Number of items processed per poll for this task\\ntask.consumer.time [timer unit=microsecond]: Wall-clock duration spent inside each task poll\\ntask.consumer.next_poll_latency [timer unit=microsecond]: Wall-clock latency between consecutive task polls\\nConsumes work from producer"];
    w1_c0 [shape=ellipse,label="ch.producer_to_consumer\\nfn: tests::channel\\nmetrics: q.producer_to_consumer.enq [counter unit=count]: Total queue enqueue events\\nq.producer_to_consumer.drain [counter unit=count]: Total queue dequeue events\\nq.producer_to_consumer.depth [gauge unit=count]: Current queue depth\\nq.producer_to_consumer.depth_dist [summary unit=count]: Distribution of observed queue depth values\\nUnsync queue carrying producer items"];
  }
  w1_t0 -> w1_c0 [label="sends\\nfn: tests::producer\\nProducer enqueues messages"];
  w1_c0 -> w1_t1 [label="receives\\nfn: tests::consumer\\nConsumer dequeues messages"];
